{
  "name": "kondi-chat",
  "version": "0.1.0",
  "description": "Multi-model AI coding CLI with intelligent routing, budget profiles, and council deliberation",
  "license": "MIT",
  "type": "module",
  "bin": {
    "kondi-chat": "./bin/kondi-chat.js"
  },
  "files": [
    "src/",
    "bin/",
    "tui/target/release/kondi-tui",
    "package.json",
    "LICENSE"
  ],
  "scripts": {
    "chat": "npx tsx src/cli/main.tsx",
    "chat:tui": "cd tui && cargo run --release",
    "chat:repl": "npx tsx src/cli/main-repl.ts",
    "build:tui": "cd tui && cargo build --release",
    "start": "npx tsx src/cli/backend.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kondi/kondi-chat"
  },
  "keywords": [
    "ai",
    "cli",
    "coding",
    "multi-model",
    "llm",
    "agent",
    "claude",
    "gpt",
    "deepseek"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "tsx": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
